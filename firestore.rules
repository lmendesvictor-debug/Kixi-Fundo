rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Catch-all safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Configuração do Kixi-Fundo - Estado Centralizado
    match /kix_fundo/state {
      // Permite leitura imediata para garantir integridade e sincronização em múltiplos ecrãs
      allow read: if true;
      
      // Validação minuciosa de integridade estrutural e tipo para escrita segura
      allow write: if true
                    && request.resource.data.keys().hasAll(['currentMonth', 'payoutsCompleted', 'members', 'logs', 'appConfig', 'updatedAt'])
                    && request.resource.data.currentMonth is int
                    && request.resource.data.currentMonth >= 1
                    && request.resource.data.currentMonth <= 6
                    && request.resource.data.members is list
                    && request.resource.data.logs is list
                    && request.resource.data.payoutsCompleted is map
                    && request.resource.data.appConfig is map
                    && request.resource.data.updatedAt is string
                    && (!('loans' in request.resource.data) || request.resource.data.loans is list);
    }

    // Histórico de Pontos de Restauro na Cloud Firestore kix_fundo_backups
    match /kix_fundo_backups/{backupId} {
      allow read, write: if true;
    }
  }
}
