rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Catch-all safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Configuração do Kixi-Fundo - Estado Centralizado
    match /kix_fundo/state {
      // Requer utilizador autenticado e com e-mail verificado para leitura das contas
      allow read: if request.auth != null && request.auth.token.email_verified == true;
      
      // Validação minuciosa de integridade, pertença e tipo para escrita
      allow write: if request.auth != null 
                    && request.auth.token.email_verified == true
                    && request.resource.data.keys().hasAll(['currentMonth', 'payoutsCompleted', 'members', 'logs', 'appConfig', 'updatedAt'])
                    && request.resource.data.currentMonth is int
                    && request.resource.data.currentMonth >= 1
                    && request.resource.data.currentMonth <= 6
                    && request.resource.data.members is list
                    && request.resource.data.logs is list
                    && request.resource.data.payoutsCompleted is map
                    && request.resource.data.appConfig is map
                    && request.resource.data.updatedAt is string;
    }
  }
}
