rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Catch-all safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Configuração do Kixi-Fundo
    match /kix_fundo/state {
      allow read: if true;
      allow write: if request.resource.data.keys().hasAll(['currentMonth', 'payoutsCompleted', 'members', 'logs', 'appConfig'])
                    && request.resource.data.currentMonth is int
                    && request.resource.data.members is list
                    && request.resource.data.logs is list;
    }
  }
}
